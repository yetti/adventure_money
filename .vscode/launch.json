{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "rdbg",
      "name": "Debug current file with rdbg",
      "request": "launch",
      "script": "${file}",
      "args": [],
      "askParameters": true
    },
    {
      "type": "rdbg",
      "name": "Attach with rdbg",
      "request": "attach"
    },
    {
      "type": "rdbg",
      "name": "Debug test file with rdbg",
      "request": "launch",
      "script": "${env:GEM_HOME}/bin/rails test",
      "args": [
        "${file}"
      ]
    },
    {
      "type": "rdbg",
      "name": "Debug system test file with rdbg",
      "request": "launch",
      "script": "${env:GEM_HOME}/bin/rails test:system",
      "args": [
        "${file}"
      ]
    },
    {
      "type": "rdbg",
      "name": "Debug test at line with rdbg",
      "request": "launch",
      "script": "${env:GEM_HOME}/bin/rails test",
      "args": [
        "${file}:${lineNumber}"
      ]
    },
    {
      "type": "rdbg",
      "name": "Debug system test at line with rdbg",
      "request": "launch",
      "script": "${env:GEM_HOME}/bin/rails test:system",
      "args": [
        "${file}:${lineNumber}"
      ]
    }
  ]
}
