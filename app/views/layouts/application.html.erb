<!DOCTYPE html>
<html data-bs-theme="">
  <head>
    <title>Adventure Money</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true, type: :module %>
    <%= javascript_include_tag "color-modes", "data-turbo-track": "reload", defer: true %>
  </head>

  <body>
    <div class="col-lg-8 mx-auto p-4 py-md-5">
      <%= render HeaderComponent.new %>
      <main>
        <%= yield %>
      </main>
    </div>
    <%= render ColorModeSwitchComponent.new %>
  </body>
</html>
