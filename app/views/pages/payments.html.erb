<div class="mb-sm-4">
  <h2>Payments</h2>
</div>

<form class="mb-2">
  <div class="row gy-2 gx-3 align-content-sm-start">
    <label for="category" class="col-md-2 col-lg-1 col-form-label">Category</label>
    <div class="col-md-4 col-md-3 col-lg-5">
      <select id="category" class="form-select" aria-label="Default select example">
        <option selected>Open this select menu</option>
        <option value="1">One</option>
        <option value="2">Two</option>
        <option value="3">Three</option>
      </select>
    </div>

    <label for="paid_by" class="col-md-2 col-lg-1 col-form-label">Paid By</label>
    <div class="col-md-4 col-md-3 col-lg-5">
      <select id="paid_by" class="form-select" aria-label="Default select example">
        <option selected>Open this select menu</option>
        <option value="1">One</option>
        <option value="2">Two</option>
        <option value="3">Three</option>
      </select>
    </div>
  </div>
  <div class="row mt-1 gy-2 gx-3 align-content-sm-start">
    <label for="date_start" class="col-md-2 col-lg-1 col-form-label">Date</label>
    <div class="col-md-4 col-md-3 col-lg-5">
      <div class="input-group mb-3">
        <input type="text" class="form-control" placeholder="" aria-label="Recipient's username" aria-describedby="button-addon2">
        <button class="btn btn-outline-secondary" type="button" id="button-addon2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-calendar-date" viewBox="0 0 16 16">
          <path d="M6.445 11.688V6.354h-.633A12.6 12.6 0 0 0 4.5 7.16v.695c.375-.257.969-.62 1.258-.777h.012v4.61h.675zm1.188-1.305c.047.64.594 1.406 1.703 1.406 1.258 0 2-1.066 2-2.871 0-1.934-.781-2.668-1.953-2.668-.926 0-1.797.672-1.797 1.809 0 1.16.824 1.77 1.676 1.77.746 0 1.23-.376 1.383-.79h.027c-.004 1.316-.461 2.164-1.305 2.164-.664 0-1.008-.45-1.05-.82h-.684zm2.953-2.317c0 .696-.559 1.18-1.184 1.18-.601 0-1.144-.383-1.144-1.2 0-.823.582-1.21 1.168-1.21.633 0 1.16.398 1.16 1.23z"/>
          <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
        </svg></button>
      </div>
    </div>

    <label for="date_end" class="col-md-2 col-lg-1 col-form-label">until</label>
    <div class="col-md-4 col-md-3 col-lg-5">
      <div class="input-group mb-3">
        <input type="text" class="form-control" placeholder="" aria-label="Recipient's username" aria-describedby="button-addon2">
        <button class="btn btn-outline-secondary" type="button" id="button-addon2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-calendar-date" viewBox="0 0 16 16">
          <path d="M6.445 11.688V6.354h-.633A12.6 12.6 0 0 0 4.5 7.16v.695c.375-.257.969-.62 1.258-.777h.012v4.61h.675zm1.188-1.305c.047.64.594 1.406 1.703 1.406 1.258 0 2-1.066 2-2.871 0-1.934-.781-2.668-1.953-2.668-.926 0-1.797.672-1.797 1.809 0 1.16.824 1.77 1.676 1.77.746 0 1.23-.376 1.383-.79h.027c-.004 1.316-.461 2.164-1.305 2.164-.664 0-1.008-.45-1.05-.82h-.684zm2.953-2.317c0 .696-.559 1.18-1.184 1.18-.601 0-1.144-.383-1.144-1.2 0-.823.582-1.21 1.168-1.21.633 0 1.16.398 1.16 1.23z"/>
          <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
        </svg></button>
      </div>
    </div>
  </div>
  <div class="row mt-1 gy-2 gx-3 align-content-sm-start">
    <label for="filter" class="col-sm-2 col-lg-1 col-form-label">Filter</label>
    <div class="col-sm-7 col-md-7 col-lg-9 col-xl-9">
      <input type="email" class="form-control" id="filter" placeholder="">
    </div>

    <div class="col-sm-3 col-md-3 col-lg-2 col-xl-2">
      <button type="button" class="btn btn-primary">Advanced</button>
    </div>
  </div>
</form>
<table class="table table-striped table-hover table-bordered caption-top">
  <caption>Payments made by Anyone for Everything for all time.</caption>
  <thead class="table-light">
  <tr>
    <th>Date</th>
    <th>Value</th>
    <th>Description</th>
    <th>Category</th>
    <th>Paid by</th>
    <th>Shared by</th>
  </tr>
  </thead>
  <tbody class="table-group-divider">
  <tr>
    <th>2022-11-01</th>
    <td>900.00</td>
    <td></td>
    <td>Rent</td>
    <td>Laszlo</td>
    <td>Rody, Laszlo, Eric</td>
  </tr>
  </tbody>
</table>
<div class="row pt-2 gx-3 align-content-sm-center justify-content-center">
  <div class="col-auto">
    <button class="btn btn-primary" type="button">New</button>
  </div>
  <div class="col-auto">
    <button class="btn btn-outline-primary" type="button">Edit</button>
  </div>
  <div class="col-auto">
    <button class="btn btn-outline-danger" type="button">Delete</button>
  </div>
</div>

